generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Product {
  id            String   @id @default(cuid())
  slug          String   @unique
  categorySlug  String
  sortOrder     Int      @default(0)
  published     Boolean  @default(true)
  featured      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  metaTitle       String?
  metaDescription String?
  priceCents      Int      @default(0)

  translations   ProductTranslation[]
  specs          ProductSpec[]
  images         ProductImage[]
  certifications Certification[]
  category       ProductCategory @relation(fields: [categorySlug], references: [slug])
  inquiries      Inquiry[]
}

model ProductTranslation {
  id          String @id @default(cuid())
  productId   String
  locale      String
  name        String
  subtitle    String?
  description String
  features    String?

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, locale])
  @@index([productId])
}

model ProductSpec {
  id        String @id @default(cuid())
  productId String
  locale    String @default("en")
  label     String
  value     String
  sortOrder Int    @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  url       String
  alt       String?
  sortOrder Int     @default(0)
  isPrimary Boolean @default(false)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model Certification {
  id        String @id @default(cuid())
  productId String
  name      String
  icon      String?
  url       String?

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model ProductCategory {
  slug        String   @id
  sortOrder   Int      @default(0)
  icon        String?
  published   Boolean  @default(true)
  translations ProductCategoryTranslation[]
  products     Product[]
}

model ProductCategoryTranslation {
  id       String @id @default(cuid())
  slug     String
  locale   String
  name     String
  subtitle String?

  category ProductCategory @relation(fields: [slug], references: [slug], onDelete: Cascade)

  @@unique([slug, locale])
  @@index([slug])
}

model Inquiry {
  id          String   @id @default(cuid())
  locale      String   @default("en")
  productId   String?
  productName String?
  company     String
  name        String
  email       String
  phone       String?
  quantity    Int?
  message     String
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  product Product? @relation(fields: [productId], references: [id])

  @@index([createdAt])
}

model Order {
  id                    String   @id @default(cuid())
  stripeSessionId       String   @unique
  stripePaymentIntentId String?
  email                 String
  name                  String?
  total                 Int
  currency              String   @default("usd")
  status                String   @default("pending")
  // JSON serialized array of cart items: [{ productId, name, price, quantity, image }]
  items                 String
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([email])
  @@index([status])
  @@index([createdAt])
}

model BlogPost {
  id          String   @id @default(cuid())
  slug        String   @unique
  locale      String   @default("en")
  title       String
  excerpt     String?
  content     String
  coverImage  String?
  category    String   @default("general")
  author      String   @default("RisunicPower")
  published   Boolean  @default(false)
  publishDate DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([locale, published])
  @@index([slug])
}

model CaseStudy {
  id          String   @id @default(cuid())
  slug        String   @unique
  locale      String   @default("en")
  title       String
  client      String
  industry    String
  challenge   String
  solution    String
  result      String
  coverImage  String?
  published   Boolean  @default(false)
  publishDate DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([locale, published])
}

model Solution {
  id          String   @id @default(cuid())
  slug        String   @unique
  locale      String   @default("en")
  title       String
  subtitle    String?
  description String
  icon        String?
  products    String?
  content     String
  published   Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([locale, published])
}
