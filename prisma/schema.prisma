generator client {
  provider        = "prisma-client-js"
  binaryTargets   = ["linux-musl-openssl-3.0.x", "windows"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Product Models ───

model Product {
  id            String   @id @default(cuid())
  slug          String   @unique
  sku           String?
  categorySlug  String
  sortOrder     Int      @default(0)
  published     Boolean  @default(true)
  featured      Boolean  @default(false)
  priceCents    Int      @default(0)
  metaTitle       String?
  metaDescription String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  translations   ProductTranslation[]
  specs          ProductSpec[]
  images         ProductImage[]
  certifications Certification[]
  reviews        ProductReview[]
  category       ProductCategory @relation(fields: [categorySlug], references: [slug])
  inquiries      Inquiry[]
}

model ProductTranslation {
  id          String @id @default(cuid())
  productId   String
  locale      String
  name        String
  subtitle    String?
  description String
  features    String?

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  @@unique([productId, locale])
  @@index([productId])
}

model ProductSpec {
  id        String @id @default(cuid())
  productId String
  locale    String @default("en")
  label     String
  value     String
  sortOrder Int    @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  @@index([productId])
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  url       String
  alt       String?
  sortOrder Int     @default(0)
  isPrimary Boolean @default(false)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  @@index([productId])
}

model Certification {
  id        String @id @default(cuid())
  productId String
  name      String

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  @@index([productId])
}

model ProductReview {
  id        String   @id @default(cuid())
  productId String
  rating    Int
  author    String   @default("Verified Buyer")
  company   String?
  country   String?
  content   String?
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  @@index([productId])
}

// ─── Category Models ───

model ProductCategory {
  slug        String   @id
  sortOrder   Int      @default(0)
  icon        String?
  published   Boolean  @default(true)
  translations ProductCategoryTranslation[]
  products     Product[]
}

model ProductCategoryTranslation {
  id       String @id @default(cuid())
  slug     String
  locale   String
  name     String
  subtitle String?

  category ProductCategory @relation(fields: [slug], references: [slug], onDelete: Cascade)
  @@unique([slug, locale])
  @@index([slug])
}

// ─── Inquiry & Order ───

model Inquiry {
  id        String   @id @default(cuid())
  locale    String   @default("en")
  company   String
  name      String
  email     String
  phone     String?
  productName String?
  productId String?
  quantity  String?
  message   String
  createdAt DateTime @default(now())

  product Product? @relation(fields: [productId], references: [id])
  @@index([createdAt])
}

model Order {
  id                  String   @id @default(cuid())
  stripeSessionId     String   @unique
  stripePaymentIntentId String
  email               String
  name                String?
  total               Int      @default(0)
  currency            String   @default("usd")
  status              String   @default("pending")
  items               String   @default("[]")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([email])
  @@index([status])
}

// ─── Content Models ───

model BlogPost {
  id          String   @id @default(cuid())
  slug        String
  locale      String   @default("en")
  title       String
  excerpt     String?
  content     String
  coverImage  String?
  category    String   @default("general")
  author      String   @default("RisunicPower")
  published   Boolean  @default(false)
  publishDate DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([slug, locale])
  @@index([locale, published])
  @@index([slug])
}

model CaseStudy {
  id          String   @id @default(cuid())
  slug        String
  locale      String   @default("en")
  title       String
  client      String
  industry    String
  challenge   String
  solution    String
  result      String
  coverImage  String?
  published   Boolean  @default(false)
  publishDate DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([slug, locale])
  @@index([locale, published])
}

model Solution {
  id          String   @id @default(cuid())
  slug        String
  locale      String   @default("en")
  title       String
  subtitle    String?
  description String
  icon        String?
  products    String?
  published   Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([slug, locale])
  @@index([locale, published])
}
